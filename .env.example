# =============================================================================
# HomeClaw - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# BUILD
# GitHub Personal Access Token with read:packages scope.
# Required at image build time to pull @asachs01/grocy-mcp from GitHub
# Packages. Not baked into the final runtime image.
# Create one at: https://github.com/settings/tokens
# -----------------------------------------------------------------------------

NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AI INFERENCE
# Provider: 'openai' (default, compatible with OpenRouter / Ollama / LiteLLM)
#           'anthropic' (use with AI_BASE_URL pointing at Anthropic or a proxy)
# -----------------------------------------------------------------------------

# Which AI SDK provider adapter to use
AI_PROVIDER=openai

# Base URL for the chat completions API.
# OpenRouter (cloud, many models):
AI_BASE_URL=https://openrouter.ai/api/v1
# Local Ollama (running on the host):
# AI_BASE_URL=http://host.docker.internal:11434/v1
# LiteLLM proxy (if you run your own):
# AI_BASE_URL=http://litellm:4000

# API key for the inference provider.
# OpenRouter — get one at https://openrouter.ai/keys
# Ollama — set to any non-empty string (e.g. "ollama")
AI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model identifier passed to the provider.
# OpenRouter examples:
AI_MODEL=openai/gpt-4o-mini
# AI_MODEL=anthropic/claude-3-haiku
# AI_MODEL=google/gemini-2.0-flash
# Local Ollama example:
# AI_MODEL=qwen2.5:7b

# -----------------------------------------------------------------------------
# GROCY
# When using bundled Grocy (--profile with-grocy) the default below points at
# the grocy service in Docker Compose and works without changes.
# Set a full URL here to point at your own external Grocy instance instead.
# -----------------------------------------------------------------------------

GROCY_URL=http://grocy:9283
# GROCY_URL=https://grocy.yourdomain.com

# Grocy API key. Create one in Grocy → Manage API Keys.
GROCY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# TELEGRAM
# 1. Talk to @BotFather on Telegram and run /newbot.
# 2. Copy the token it gives you into TELEGRAM_BOT_TOKEN.
# 3. Add the bot to your household group or chat.
# 4. Optionally restrict to specific chat IDs (comma-separated).
#    Leave TELEGRAM_CHAT_IDS empty to allow any chat.
# -----------------------------------------------------------------------------

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_IDS=

# -----------------------------------------------------------------------------
# WHATSAPP (via @whiskeysockets/baileys)
# On first run a QR code is printed to stdout — scan it with WhatsApp.
# Session credentials are saved to WHATSAPP_AUTH_DIR and reused on restart.
# -----------------------------------------------------------------------------

WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=/data/whatsapp-auth

# -----------------------------------------------------------------------------
# DISCORD (via discord.js)
# 1. Create an application at https://discord.com/developers/applications
# 2. Add a Bot, enable Message Content Intent, and copy the token below.
# 3. Invite the bot to your server with the appropriate permissions.
# 4. Optionally restrict to specific channel IDs (comma-separated).
# -----------------------------------------------------------------------------

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_IDS=

# -----------------------------------------------------------------------------
# HOUSEHOLD
# -----------------------------------------------------------------------------

# Display name for the household (used in agent responses)
HOUSEHOLD_NAME=Home

# Wake word / trigger prefix. The agent only responds in groups when a message
# contains this word (case-insensitive). In private chat it responds to all.
TRIGGER_WORD=@home

# -----------------------------------------------------------------------------
# STORAGE
# These default to /data which is the container's persistent volume mount.
# Rarely need to change unless running outside Docker.
# -----------------------------------------------------------------------------

DB_PATH=/data/homeclaw.db
CONTEXT_FILE=/data/CONTEXT.md
SESSIONS_DIR=/data/sessions

# -----------------------------------------------------------------------------
# OPTIONAL TUNING
# -----------------------------------------------------------------------------

# Timezone for the bundled Grocy container and log timestamps.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Maximum number of tool-use steps the agent may take per turn
MAX_STEPS=20

# How many past messages to keep in the agent's context window
MAX_HISTORY_MESSAGES=60

# How often the background scheduler runs (milliseconds)
SCHEDULER_INTERVAL_MS=60000

# Cloudflare Tunnel token. Required only when using --profile tunnel.
# Create a tunnel at https://one.dash.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
