# =============================================================================
# HomeClaw - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Path to the SQLite database file
DB_PATH=/data/homeclaw.db

# Path to the per-household context file (loaded into the agent system prompt)
CONTEXT_FILE=/data/CONTEXT.md

# Directory for persistent session data
SESSIONS_DIR=/data/sessions

# -----------------------------------------------------------------------------
# AI Inference
# Provider: 'openai' (default, used for LiteLLM / Ollama) or 'anthropic'
# -----------------------------------------------------------------------------

# Which SDK provider to use
AI_PROVIDER=openai

# Model name as exposed by your inference server
AI_MODEL=qwen2.5:7b-instruct

# Base URL for the OpenAI-compatible API (LiteLLM proxy in Docker Compose)
AI_BASE_URL=http://litellm:4000

# API key for the inference server (LiteLLM master key or any string for Ollama)
AI_API_KEY=homeclaw

# -----------------------------------------------------------------------------
# Household
# -----------------------------------------------------------------------------

# Display name for the household (used in agent responses)
HOUSEHOLD_NAME=Home

# Trigger word for group chats - the agent only responds when a message
# contains this word (case-insensitive). Set to empty to respond to everything.
TRIGGER_WORD=@home

# -----------------------------------------------------------------------------
# WhatsApp (via @whiskeysockets/baileys)
# On first run a QR code will be printed to stdout - scan it with WhatsApp.
# Session credentials are saved to WHATSAPP_AUTH_DIR and reused on restart.
# -----------------------------------------------------------------------------

WHATSAPP_ENABLED=true

# Directory where WhatsApp auth session files are stored
WHATSAPP_AUTH_DIR=/data/whatsapp-auth

# -----------------------------------------------------------------------------
# Telegram (via Telegraf)
# 1. Create a bot with @BotFather on Telegram.
# 2. Copy the token it gives you into TELEGRAM_BOT_TOKEN.
# 3. Add the bot to your household group/chat.
# 4. Optionally restrict the bot to specific chat IDs (comma-separated).
#    Leave TELEGRAM_CHAT_IDS empty to allow any chat.
# -----------------------------------------------------------------------------

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# -----------------------------------------------------------------------------
# Discord (via discord.js)
# 1. Create an application at https://discord.com/developers/applications
# 2. Add a Bot, enable Message Content Intent, and copy the token below.
# 3. Invite the bot to your server with the appropriate permissions.
# 4. Optionally restrict to specific channel IDs (comma-separated).
# -----------------------------------------------------------------------------

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=

# -----------------------------------------------------------------------------
# Agent tuning
# -----------------------------------------------------------------------------

# Maximum number of chat history messages to include in each agent call
MAX_HISTORY_MESSAGES=60

# Maximum number of tool-use steps the agent may take per turn
MAX_STEPS=20

# How often the background scheduler runs (milliseconds)
SCHEDULER_INTERVAL_MS=60000
